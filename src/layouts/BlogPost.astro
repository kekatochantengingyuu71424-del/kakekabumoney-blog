---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <Header />
    <main>
      <article>
        <header class="article-header">
          <div class="article-meta">
            <time class="article-date">
              <FormattedDate date={pubDate} />
            </time>
            {updatedDate && (
              <span class="article-updated">
                更新：<FormattedDate date={updatedDate} />
              </span>
            )}
          </div>
          <h1 class="article-title">{title}</h1>
          {description && <p class="article-desc">{description}</p>}
          <hr class="article-divider" />
        </header>

        <div class="prose">
          <slot />
        </div>

        <div class="article-footer">
          <a href="/blog" class="back-link">← 記事一覧に戻る</a>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  .article-header {
    padding: 2em 0 0;
    margin-bottom: 2em;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1em;
    margin-bottom: 0.75em;
  }

  .article-date {
    font-size: 0.85em;
    color: var(--text-light);
    font-weight: 500;
  }

  .article-updated {
    font-size: 0.8em;
    color: var(--text-light);
  }

  .article-title {
    font-size: 1.75em;
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 0.5em;
    color: var(--text);
  }

  .article-desc {
    font-size: 1em;
    color: var(--text-muted);
    line-height: 1.75;
    margin: 0;
  }

  .article-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.5em 0 0;
  }

  .prose {
    font-size: 1em;
    line-height: 1.9;
    color: var(--text);
  }

  .prose :global(h2) {
    font-size: 1.35em;
    margin: 2em 0 0.75em;
    padding-bottom: 0.4em;
    border-bottom: 2px solid var(--border);
  }

  .prose :global(h3) {
    font-size: 1.15em;
    margin: 1.75em 0 0.5em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.25em;
  }

  .prose :global(li) {
    margin-bottom: 0.35em;
    line-height: 1.8;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .prose :global(img) {
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    margin: 1.5em 0;
  }

  .article-footer {
    margin-top: 3em;
    padding-top: 1.5em;
    border-top: 1px solid var(--border);
  }

  .back-link {
    font-size: 0.875em;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .article-title { font-size: 1.4em; }
  }
</style>
