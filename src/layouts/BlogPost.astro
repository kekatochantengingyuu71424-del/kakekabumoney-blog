---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import AuthorBox from '../components/AuthorBox.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

type Props = CollectionEntry<'blog'>['data'] & {
  headings?: MarkdownHeading[];
  slug?: string;
};

const { title, description, pubDate, updatedDate, headings = [], slug, category } = Astro.props;

const CATEGORY_LABELS: Record<string, string> = {
  'japan-stock': '日本株',
  'us-stock': '米国株',
  'household': '家計',
};

const shareUrl = slug
  ? new URL(`/blog/${slug}/`, Astro.site ?? Astro.url).toString()
  : Astro.url.toString();
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <Header />
    <main>
      <article>
        <header class="article-header">
          <div class="article-meta">
            {category && (
              <a href={`/blog/category/${category}/`} class="article-category">
                {CATEGORY_LABELS[category]}
              </a>
            )}
            <time class="article-date">
              <FormattedDate date={pubDate} />
            </time>
            {updatedDate && (
              <span class="article-updated">
                更新：<FormattedDate date={updatedDate} />
              </span>
            )}
          </div>
          <h1 class="article-title">{title}</h1>
          {description && <p class="article-desc">{description}</p>}
          <hr class="article-divider" />
        </header>

        {headings.length > 0 && <TableOfContents headings={headings} />}

        <div class="prose">
          <slot />
        </div>

        <ShareButtons title={title} url={shareUrl} />

        {slug && <RelatedPosts currentSlug={slug} />}

        <AuthorBox />

        <div class="article-footer">
          <a href="/blog" class="back-link">← 記事一覧に戻る</a>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  .article-header {
    padding: 2em 0 0;
    margin-bottom: 2em;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1em;
    margin-bottom: 0.75em;
  }

  .article-category {
    display: inline-block;
    font-size: 0.75em;
    font-weight: 700;
    color: var(--accent);
    background: #EBF2FF;
    border-radius: 4px;
    padding: 0.2em 0.7em;
    text-decoration: none;
  }

  .article-category:hover {
    background: #DBEAFE;
    text-decoration: none;
  }

  .article-date {
    font-size: 0.85em;
    color: var(--text-light);
    font-weight: 500;
  }

  .article-updated {
    font-size: 0.8em;
    color: var(--text-light);
  }

  .article-title {
    font-size: 1.75em;
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 0.5em;
    color: var(--text);
  }

  .article-desc {
    font-size: 1em;
    color: var(--text-muted);
    line-height: 1.75;
    margin: 0;
  }

  .article-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.5em 0 0;
  }

  .prose {
    font-size: 1em;
    line-height: 1.9;
    color: var(--text);
  }

  .prose :global(h2) {
    font-size: 1.35em;
    margin: 2em 0 0.75em;
    padding-bottom: 0.4em;
    border-bottom: 2px solid var(--border);
    scroll-margin-top: 80px;
  }

  .prose :global(h3) {
    font-size: 1.15em;
    margin: 1.75em 0 0.5em;
    scroll-margin-top: 80px;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.25em;
  }

  .prose :global(li) {
    margin-bottom: 0.35em;
    line-height: 1.8;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .prose :global(img) {
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    margin: 1.5em 0;
  }

  .article-footer {
    margin-top: 2em;
    padding-top: 1.5em;
    border-top: 1px solid var(--border);
  }

  .back-link {
    font-size: 0.875em;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .article-title { font-size: 1.4em; }
  }
</style>
