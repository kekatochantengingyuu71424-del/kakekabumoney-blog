---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';

const CATEGORY_LABELS: Record<string, string> = {
  'japan-stock': '日本株',
  'us-stock': '米国株',
  'household': '家計',
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const categories = ['japan-stock', 'us-stock', 'household'];
  return categories.map((category) => ({
    params: { category },
    props: {
      posts: posts
        .filter((p) => p.data.category === category)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { category } = Astro.params;
const { posts } = Astro.props;
const label = CATEGORY_LABELS[category] ?? category;
---

<html lang="ja">
  <head>
    <BaseHead title={`${label}の記事一覧 | かけかぶマネーブログ`} description={`${label}カテゴリの記事一覧です。`} />
  </head>
  <body>
    <Header />
    <main>
      <section>
        <div class="category-header">
          <span class="category-badge">{label}</span>
          <h1 class="category-title">{label}の記事一覧</h1>
          <p class="category-count">{posts.length}件の記事</p>
        </div>
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-item">
              <a href={`/blog/${post.id}/`} class="post-link">
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-desc">{post.data.description}</p>
                <time class="post-date"><FormattedDate date={post.data.pubDate} /></time>
              </a>
            </li>
          ))}
        </ul>
        <a href="/blog" class="back-link">← 記事一覧に戻る</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .category-header {
    padding: 2em 0 1.5em;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2em;
  }

  .category-badge {
    display: inline-block;
    font-size: 0.75em;
    font-weight: 700;
    color: var(--accent);
    background: #EBF2FF;
    border-radius: 4px;
    padding: 0.2em 0.7em;
    margin-bottom: 0.5em;
  }

  .category-title {
    font-size: 1.5em;
    font-weight: 700;
    margin: 0.25em 0 0.25em;
    color: var(--text);
  }

  .category-count {
    font-size: 0.85em;
    color: var(--text-muted);
    margin: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2em;
    display: flex;
    flex-direction: column;
    gap: 1em;
  }

  .post-item {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .post-link {
    display: block;
    padding: 1.25em 1.5em;
    text-decoration: none;
    transition: background 0.15s;
  }

  .post-link:hover {
    background: #F9FAFB;
  }

  .post-title {
    font-size: 1.05em;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.4em;
    line-height: 1.5;
  }

  .post-desc {
    font-size: 0.875em;
    color: var(--text-muted);
    margin: 0 0 0.6em;
    line-height: 1.6;
  }

  .post-date {
    font-size: 0.8em;
    color: var(--text-light);
  }

  .back-link {
    font-size: 0.875em;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--accent);
  }
</style>
