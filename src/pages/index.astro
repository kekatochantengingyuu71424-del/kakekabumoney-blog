---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="hero-badge">お金の情報ブログ</div>
        <h1 class="hero-title">日本株と家計管理で<br />お金の自由を目指す</h1>
        <p class="hero-desc">
          投資初心者から中級者向けに、日本株の分析・配当投資・家計改善の情報を<br class="pc-only" />
          わかりやすくお届けします。
        </p>
        <div class="hero-tags">
          <span class="tag tag-blue">📈 日本株</span>
          <span class="tag tag-green">💰 配当投資</span>
          <span class="tag tag-orange">🏠 家計管理</span>
        </div>
      </section>

      <!-- 最新記事 -->
      <section class="section">
        <h2 class="section-title">最新記事</h2>
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-card">
              <a href={`/blog/${post.id}/`} class="post-link">
                <div class="post-info">
                  <h3 class="post-title">{post.data.title}</h3>
                  {post.data.description && (
                    <p class="post-desc">{post.data.description}</p>
                  )}
                  <time class="post-date">
                    <FormattedDate date={post.data.pubDate} />
                  </time>
                </div>
              </a>
            </li>
          ))}
        </ul>
        <div class="more-link-wrap">
          <a href="/blog" class="more-link">記事一覧をもっと見る →</a>
        </div>
      </section>

      <!-- このブログについて -->
      <section class="about-card">
        <h2>このブログについて</h2>
        <p>
          「かけかぶマネーブログ」は、<strong>日本株への投資</strong>と<strong>家計の最適化</strong>をテーマにしたブログです。
          投資歴を重ねながら、実際に試した銘柄選びの方法や、毎月の家計見直しで貯蓄を増やすコツをシェアしています。
        </p>
        <a href="/about" class="btn">詳しく読む</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: 3em 0 2.5em;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5em;
  }
  .hero-badge {
    display: inline-block;
    font-size: 0.75em;
    font-weight: 700;
    color: var(--accent);
    background: #EBF2FF;
    border-radius: 99px;
    padding: 0.3em 0.9em;
    margin-bottom: 1em;
    letter-spacing: 0.04em;
  }
  .hero-title {
    font-size: 2em;
    line-height: 1.35;
    margin: 0 0 0.6em;
    color: var(--text);
  }
  .hero-desc {
    font-size: 0.95em;
    color: var(--text-muted);
    margin: 0 0 1.5em;
    line-height: 1.8;
  }
  .hero-tags {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5em;
  }
  .tag {
    display: inline-block;
    font-size: 0.8em;
    font-weight: 500;
    padding: 0.3em 0.8em;
    border-radius: 99px;
  }
  .tag-blue  { background: #EBF2FF; color: #1A56DB; }
  .tag-green { background: #ECFDF5; color: #059669; }
  .tag-orange{ background: #FFF7ED; color: #C2410C; }

  /* Section */
  .section { margin-bottom: 3em; }
  .section-title {
    font-size: 1.05em;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-bottom: 1em;
    padding-bottom: 0.5em;
    border-bottom: 2px solid var(--border);
  }

  /* Post list */
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .post-card {
    border-bottom: 1px solid var(--border-light);
  }
  .post-link {
    display: block;
    padding: 1.2em 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }
  .post-link:hover {
    opacity: 0.75;
    text-decoration: none;
  }
  .post-title {
    font-size: 1.05em;
    font-weight: 700;
    margin: 0 0 0.3em;
    color: var(--text);
    line-height: 1.5;
  }
  .post-desc {
    font-size: 0.875em;
    color: var(--text-muted);
    margin: 0 0 0.4em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-date {
    font-size: 0.8em;
    color: var(--text-light);
  }

  /* More link */
  .more-link-wrap { margin-top: 1.25em; text-align: right; }
  .more-link {
    font-size: 0.875em;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .more-link:hover { text-decoration: underline; }

  /* About card */
  .about-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75em 2em;
    margin-bottom: 2em;
  }
  .about-card h2 {
    font-size: 1.1em;
    margin-bottom: 0.75em;
  }
  .about-card p {
    font-size: 0.9em;
    color: var(--text-muted);
    margin-bottom: 1em;
    line-height: 1.8;
  }
  .btn {
    display: inline-block;
    padding: 0.5em 1.25em;
    background: var(--accent);
    color: #fff;
    border-radius: 6px;
    font-size: 0.875em;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn:hover { background: var(--accent-hover); text-decoration: none; }

  .pc-only { display: none; }
  @media (min-width: 640px) { .pc-only { display: inline; } }

  @media (max-width: 600px) {
    .hero-title { font-size: 1.5em; }
    .about-card { padding: 1.25em 1.25em; }
  }
</style>
