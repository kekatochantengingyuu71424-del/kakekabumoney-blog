---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// h2 と h3 のみ表示（h1は記事タイトルなので除外）
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{tocHeadings.length > 0 && (
  <nav class="toc" aria-label="目次">
    <details open>
      <summary>
        <span class="toc-icon">📑</span>
        <span>目次</span>
      </summary>
      <ol class="toc-list">
        {tocHeadings.map((heading) => (
          <li class={`toc-item depth-${heading.depth}`}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ol>
    </details>
  </nav>
)}

<style>
  .toc {
    background: #F9FAFB;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 2em 0;
    padding: 1em 1.25em;
  }

  details {
    margin: 0;
  }

  summary {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-size: 0.95em;
    font-weight: 700;
    color: var(--text);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: '▼';
    margin-left: auto;
    font-size: 0.7em;
    color: var(--text-muted);
    transition: transform 0.2s;
  }

  details:not([open]) summary::after {
    transform: rotate(-90deg);
  }

  .toc-icon {
    font-size: 1em;
  }

  .toc-list {
    margin: 0.75em 0 0;
    padding: 0 0 0 0.5em;
    list-style: none;
    counter-reset: toc-counter;
  }

  .toc-item {
    margin: 0.4em 0;
    line-height: 1.5;
    font-size: 0.875em;
  }

  .toc-item.depth-2 {
    padding-left: 0;
    font-weight: 500;
    counter-increment: toc-counter;
  }

  .toc-item.depth-2::before {
    content: counter(toc-counter) '. ';
    color: var(--text-muted);
    font-weight: 600;
    margin-right: 0.25em;
  }

  .toc-item.depth-3 {
    padding-left: 1.5em;
    font-size: 0.85em;
  }

  .toc-item.depth-3::before {
    content: '└ ';
    color: var(--text-light);
  }

  .toc-item a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .toc-item a:hover {
    color: var(--accent);
    text-decoration: underline;
  }
</style>
