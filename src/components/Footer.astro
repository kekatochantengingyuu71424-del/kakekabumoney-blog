---
const today = new Date();
---

<footer>
  <div class="footer-inner">
    <p class="footer-logo">💴 かけかぶマネーブログ</p>
    <p class="footer-desc">日本株投資と家計管理で、お金の自由を目指す。</p>
    <p class="footer-copy">&copy; {today.getFullYear()} かけかぶマネーブログ. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    margin-top: 4em;
    border-top: 1px solid var(--border);
    background: #fff;
  }

  .footer-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 2.5em 1.5em;
    text-align: center;
  }

  .footer-logo {
    font-size: 1em;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.4em;
  }

  .footer-desc {
    font-size: 0.875em;
    color: var(--text-muted);
    margin: 0 0 1em;
  }

  .footer-copy {
    font-size: 0.8em;
    color: var(--text-light);
    margin: 0;
  }
</style>
