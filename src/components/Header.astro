---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <div class="header-inner">
    <a href="/" class="logo" aria-label={SITE_TITLE}>
      <span class="logo-icon">か</span>
      <span class="logo-text">{SITE_TITLE}</span>
    </a>
    <nav>
      <HeaderLink href="/">ホーム</HeaderLink>
      <HeaderLink href="/blog">記事一覧</HeaderLink>
      <HeaderLink href="/about">このブログについて</HeaderLink>
    </nav>
  </div>
</header>

<style>
  header {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5em;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1em;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.55em;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.15s var(--ease);
  }

  .logo:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .logo-icon {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-light) 100%);
    color: #fff;
    font-size: 0.92em;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 6px rgba(30, 64, 175, 0.25);
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 0.95em;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 0.15em;
  }

  @media (max-width: 600px) {
    .header-inner { height: 54px; padding: 0 1em; }
    .logo-icon { width: 26px; height: 26px; font-size: 0.85em; }
    .logo-text { font-size: 0.85em; }
    nav :global(a) {
      font-size: 0.78em;
      padding: 0.4em 0.5em;
    }
  }
</style>
